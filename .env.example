# Скопируйте этот файл в `.env` и укажите реальные значения.
# Сам файл `.env` никогда не должен попадать в git.

DEBUG=True
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (используется автоматически при запуске через docker-compose)
POSTGRES_DB=marketpulse
POSTGRES_USER=marketpulse
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Ключи API маркетплейсов — никогда не коммитьте реальные ключи, только в локальный .env
WILDBERRIES_API_KEY=
UZUM_API_KEY=

# Зарезервировано для будущих AI-функций (например, Claude API для авто-категоризации и поиска аномалий)
ANTHROPIC_API_KEY=
